# TeslaLink API Configuration — EXAMPLE (copy to .env and fill in real values)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=teslamate
DB_USER=teslamate
DB_PASS=your_db_password_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# PIN Auth
APP_PIN_HASH=your_pin_hash_here
APP_SALT=your_salt_here

# Server
PORT=3001
